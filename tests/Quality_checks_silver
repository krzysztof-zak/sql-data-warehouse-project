---------------------------------------------------------
--Cleaning bronze.crm_prd_info
---------------------------------------------------------

-- Checking for duplicates in the data from bronze layer
select
prd_id,
count(*)
from bronze.crm_prd_info
group by prd_id
having count(*) != 1
or prd_id is null;

-- Checking for leading or trailing spaces in prd_key
select
prd_key
from bronze.crm_prd_info
where prd_key != trim(prd_key);

/*Deriving cat_id from prd_key in order to be able to join with silver.erp_px_cat_g1v2
  and checking if these values appear in silver.erp_px_cat_g1v2 id */
select
REPLACE(SUBSTRING(prd_key, 1, 5), '-', '_') AS cat_id
from bronze.crm_prd_info
Where REPLACE(SUBSTRING(prd_key, 1, 5), '-', '_') not in (select id from bronze.erp_px_cat_g1v2)

-- Deriving second part from prd_key in order to be able to join with crm_sales_details
select
SUBSTRING(prd_key, 7, len(prd_key)) as prd_key
from bronze.crm_prd_info;

-- Checking for leading or trailing spaces in prd_nm
select
prd_nm
from bronze.crm_prd_info
where prd_nm != trim(prd_nm)

-- Checking for NULLs or negative numbers in prd_cost
select
prd_id,
prd_cost
from bronze.crm_prd_info
where prd_cost is null
	  or prd_cost < 0;

-- Replacing NULLs in prd_cost with 0s
select
ISNULL(prd_cost, 0) as prd_cost
from bronze.crm_prd_info

--Checkin cardinality in prd_line
select distinct
prd_line
from bronze.crm_prd_info;

--Making prd_line more readable and user friendly
select
	case upper(trim(prd_line))
		when 'R' then 'Road'
		when 'M' then 'Mountain'
		when 'S' then 'other Sales'
		when 'T' then 'Touring'
		else 'N/A'
	end as prd_line
from bronze.crm_prd_info;

-- Checking prd_start_dt and prd_end_dt if end isn't smaller than start

select
prd_start_dt,
prd_end_dt
from bronze.crm_prd_info
where prd_end_dt < prd_start_dt;

-- Date quality is poor, so the end date will be derived as one day before the next start date.

SELECT
prd_key,
prd_start_dt,
lead(prd_start_dt) over(partition by prd_key order by prd_start_dt) -1 end_dt
from bronze.crm_prd_info

