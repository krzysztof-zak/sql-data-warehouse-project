---------------------------------------------------------

--Checking for Leading or Trailing spaces in sls_ord_num
SELECT
*
FROM bronze.crm_sales_details
WHERE sls_ord_num != TRIM(sls_ord_num);

--No spaces detected

--Checking if all keys in sls_prd_key have match in silver.crm_prd_info

SELECT
*
FROM bronze.crm_sales_details
WHERE sls_prd_key NOT IN (SELECT prd_key FROM silver.crm_prd_info);

--No keys without match detected

--Checking if all keys in sls_cust_id have match in silver.crm_cust_info

SELECT
*
FROM bronze.crm_sales_details
WHERE sls_cust_id NOT IN (SELECT cst_id FROM silver.crm_cust_info);

--No keys without match detected

--sls_order_dt
--Checking if there are dates that are less or equall to 0

SELECT
*
FROM bronze.crm_sales_details
WHERE sls_order_dt =0;

--Replacing 0s with NULLs
--Checking if all dates have lenght of 8 characters, if not also replacing with NULLs

SELECT
	CASE
		WHEN sls_order_dt = 0 
			 OR LEN(sls_order_dt) != 8 
		THEN NULL
		ELSE CAST(CAST(sls_order_dt AS VARCHAR) AS DATE)
	END AS sls_order_dt
FROM bronze.crm_sales_details;

--Repeating the same process with sls_ship_dt

SELECT
*
FROM bronze.crm_sales_details
WHERE sls_ship_dt =0
OR LEN(sls_ship_dt) != 8
OR sls_ship_dt > 20500101
OR sls_ship_dt < 19000101

--sls_ship_dt is clean but for future updates applying the same rules as with sls_order_dt

SELECT
	CASE
		WHEN sls_ship_dt = 0 
			 OR LEN(sls_ship_dt) != 8 
		THEN NULL
		ELSE CAST(CAST(sls_ship_dt AS VARCHAR) AS DATE)
	END AS sls_ship_dt
FROM bronze.crm_sales_details;

--sls_due_dt

SELECT
*
FROM bronze.crm_sales_details
WHERE sls_due_dt =0
OR LEN(sls_due_dt) != 8
OR sls_due_dt > 20500101
OR sls_due_dt < 19000101;

SELECT
	CASE
		WHEN sls_due_dt = 0 
			 OR LEN(sls_due_dt) != 8 
		THEN NULL
		ELSE CAST(CAST(sls_due_dt AS VARCHAR) AS DATE)
	END AS sls_due_dt
FROM bronze.crm_sales_details;

--Checking if there are any sls_order_dt later than sls_ship_dt or sls_due_dt

SELECT
*
FROM bronze.crm_sales_details
WHERE sls_order_dt > sls_ship_dt OR sls_order_dt > sls_due_dt;

-- There are no out of order sls_order_dt

--Checking quality of sls_sales, sls_quantity and sls_price

SELECT
*
FROM bronze.crm_sales_details
WHERE sls_price IS NULL
OR sls_price <= 0;

--There are sls_price less than 0 and NULL

SELECT
*
FROM bronze.crm_sales_details
WHERE sls_quantity IS NULL
OR sls_quantity <= 0;

--sls_quantity is clean

SELECT
*
FROM bronze.crm_sales_details
WHERE sls_sales IS NULL
OR sls_sales <= 0;

--There are sls_sales less or equall than 0 and NULL

SELECT
*
FROM bronze.crm_sales_details
WHERE sls_sales != sls_price * sls_quantity;

--There are sls_sales that are not equall to sls_sales * sls_quantity

--Cleaning sls_sales and sls_price

SELECT DISTINCT
sls_sales AS old_sales,
sls_quantity,
sls_price AS old_price,
CASE
	WHEN sls_sales <= 0 OR sls_sales IS NULL OR sls_sales != ABS(sls_price) * sls_quantity
	THEN ABS(sls_price) * sls_quantity
	ELSE sls_sales
END AS sls_sales,
CASE
	WHEN sls_price <= 0 OR sls_price IS NULL 
	THEN sls_sales / NULLIF(sls_quantity, 0)
	ELSE sls_price
END AS sls_price
FROM bronze.crm_sales_details
WHERE sls_sales != sls_price * sls_quantity OR
	  sls_sales IS NULL OR sls_price IS NULL OR sls_quantity IS NULL
	  OR sls_sales <= 0 OR sls_price <= 0 OR sls_sales <= 0
ORDER BY sls_sales, sls_quantity, sls_price 

